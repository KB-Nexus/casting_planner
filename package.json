{
  "name": "casting-planner",
  "version": "1.0.0",
  "description": "Kenan Metal Döküm Planlayıcı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Kenan Metal",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.kenanmetal.castingplanner",
    "productName": "Kenan Metal Döküm Planlayıcı",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "icon.ico",
      "kenan-metal-logo.png",
      "report-logo.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Döküm Planlayıcı",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "playwright-chromium": "^1.60.0",
    "png-to-ico": "^3.0.1"
  }
}
