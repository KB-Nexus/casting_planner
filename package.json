{
  "name": "casting-planner",
  "version": "1.6.15",
  "description": "Kenan Metal Döküm Planlayıcı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "cloud:deploy": "npx wrangler deploy --config cloud/wrangler.toml",
    "cloud:db:init": "npx wrangler d1 migrations apply casting-plan --remote --config cloud/wrangler.toml",
    "update:publish": "powershell -ExecutionPolicy Bypass -File scripts/publish-update.ps1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Kenan Metal",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.kenanmetal.castingplanner",
    "productName": "Kenan Metal Döküm Planlayıcı",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "generic",
      "url": "https://kenan-metal-casting-plan.kbnexusapps.workers.dev/updates"
    },
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "icon.ico",
      "kenan-metal-logo.png",
      "report-logo.png",
      "package.json",
      "cloud-plan.config.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Döküm Planlayıcı",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "playwright-chromium": "^1.60.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
